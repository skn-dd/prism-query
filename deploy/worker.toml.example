# /etc/prism/worker.toml — Prism worker configuration example.
#
# Precedence (lowest to highest):
#   1. Built-in defaults compiled into prism-worker
#   2. This file (passed via --config, or auto-loaded from /etc/prism/worker.toml)
#   3. Environment variables prefixed PRISM_ (e.g. PRISM_SERVER_BIND)
#   4. CLI flags (--port, --data-dir, ...)
#
# Copy to /etc/prism/worker.toml, edit, then start the worker with
# `prism-worker` (no flags) or `prism-worker --config /path/to/worker.toml`.

[server]
# host:port the gRPC/Flight server binds to.
bind = "0.0.0.0:50051"
# gRPC max decoding/encoding message size. Raise for large RecordBatches.
max_message_size_mb = 256

[runtime]
# Memory budget for the worker (GB). 0 = unlimited.
max_memory_gb = 0
# Worker thread pool size. 0 = num_cpus.
worker_threads = 0

[data]
# Default data directory for local-Parquet mode (legacy/bench).
# For cloud deployments, tables are resolved via URIs in the execute
# command and this field can be omitted.
data_dir = "/data/prism"

[logging]
# One of: trace, debug, info, warn, error
level = "info"
# One of: pretty, json
format = "pretty"

[tls]
# mTLS for the Arrow Flight gRPC transport. Production deployments MUST
# leave `enabled = true`; `false` is an escape hatch for local dev only.
#
# Cert rotation: this slice rotates via pod restart. Mount cert-manager
# Certificate material as a Kubernetes Secret at the paths below. When
# the Secret updates, recreate the pod. Hot-reload is a follow-up.
#
# The PEM files are expected to be:
#   cert_path:       server certificate chain (leaf first)
#   key_path:        server private key (PKCS#8 / RSA / SEC1)
#   client_ca_path:  CA bundle used to verify the CLIENT cert (mTLS).
#                    Empty string → server-auth-only TLS (not recommended).
#   client_cn_pattern:
#                    Optional pattern a peer cert's CN/SAN must match.
#                    Empty = accept any peer cert signed by the CA.
#                    Enforcement will land with the authorization hook.
enabled = true
cert_path = "/etc/prism/tls/server.crt"
key_path  = "/etc/prism/tls/server.key"
client_ca_path = "/etc/prism/tls/ca.crt"
client_cn_pattern = ""

# -----------------------------------------------------------------------------
# Reserved namespaces — not yet implemented. The prism-worker binary accepts
# these sections in the file but will not use them until later phases.
# -----------------------------------------------------------------------------

